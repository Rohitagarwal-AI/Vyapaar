# Backend
DATABASE_URL=sqlite:///./vyapaarai.db
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# AI provider options: local, openai, gemini
# local mode uses deterministic fallback logic and needs no API key.
AI_PROVIDER=local

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Frontend
VITE_API_URL=http://localhost:8000/api

